{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend",
      "program": "${workspaceFolder}/backend_MG/src/app.ts",
      "runtimeArgs": [
        "--require", "ts-node/register"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "cwd": "${workspaceFolder}/backend_MG",
      "outFiles": ["${workspaceFolder}/backend_MG/dist/**/*.js"],
      "autoAttachChildProcesses": true
    }
  ]
}
